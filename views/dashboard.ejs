<%- include('layouts/header') %>

    <body>
        <div class="container-fluid">
            <div class="row">
                <%- include('layouts/sidebar') %>

                    <main class="col-md-10 ms-sm-auto px-md-4 py-4">
                        <div class="row g-4 mb-4">
                            <div class="col-md-4">
                                <div class="card stat-card bg-primary text-white p-3">
                                    <div class="d-flex justify-content-between">
                                        <div>
                                            <p class="mb-1">Total Products</p>
                                            <h2 class="fw-bold">350</h2>
                                        </div>
                                        <i class="bi bi-box fs-1 opacity-50"></i>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="card stat-card bg-success text-white p-3">
                                    <div class="d-flex justify-content-between">
                                        <div>
                                            <p class="mb-1">Today's Sales</p>
                                            <h2 class="fw-bold">₹45,000</h2>
                                        </div>
                                        <i class="bi bi-currency-rupee fs-1 opacity-50"></i>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="card stat-card bg-danger text-white p-3">
                                    <div class="d-flex justify-content-between">
                                        <div>
                                            <p class="mb-1">Low Stock Alert</p>
                                            <h2 class="fw-bold">15</h2>
                                        </div>
                                        <i class="bi bi-exclamation-triangle fs-1 opacity-50"></i>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="card p-4 mb-4">
                            <h5 class="fw-bold mb-3">Product List</h5>
                            <div class="table-responsive">
                                <table class="table table-hover align-middle">
                                    <thead class="table-light">
                                        <tr>
                                            <th>SKU</th>
                                            <th>Product Name</th>
                                            <th>Category</th>
                                            <th>Stock</th>
                                            <th>Price</th>
                                            <th>Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr>
                                            <td>SKU001</td>
                                            <td>Laptop</td>
                                            <td>Electronics</td>
                                            <td><span class="badge bg-success">50</span></td>
                                            <td>₹65,000</td>
                                            <td>
                                                <button class="btn btn-sm btn-outline-primary"><i
                                                        class="bi bi-pencil"></i></button>
                                                <button class="btn btn-sm btn-outline-danger"><i
                                                        class="bi bi-trash"></i></button>
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>

                        <div class="card p-4">
                            <h5 class="fw-bold mb-3">Payment & Due Tracking</h5>
                            <div class="table-responsive">
                                <table class="table align-middle">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Order ID</th>
                                            <th>Customer</th>
                                            <th>Total</th>
                                            <th>Status</th>
                                            <th>Action</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr>
                                            <td>#ORD102</td>
                                            <td>Rajesh Kumar</td>
                                            <td>₹12,500</td>
                                            <td><span
                                                    class="badge rounded-pill bg-success-subtle text-success border border-success">Paid</span>
                                            </td>
                                            <td><button class="btn btn-sm btn-light">View</button></td>
                                        </tr>
                                        <tr>
                                            <td>#ORD105</td>
                                            <td>Amit Sharma</td>
                                            <td>₹8,000</td>
                                            <td><span
                                                    class="badge rounded-pill bg-danger-subtle text-danger border border-danger">Due</span>
                                            </td>
                                            <td><button class="btn btn-sm btn-primary">Pay Now</button></td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </main>
                    <!-- Bootstrap CDN -->
                    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    </body>

    </html>