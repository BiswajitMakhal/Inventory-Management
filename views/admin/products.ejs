<%- include('../layouts/header') %>

    <body>
        <div class="container-fluid">
            <div class="row">
                <%- include('../layouts/sidebar') %>

                    <main class="col-md-10 ms-sm-auto px-md-4 py-4">
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <h2 class="fw-bold">Products</h2>
                            <div>
                                <a href="/products/export/csv" class="btn btn-success me-2">
                                    <i class="bi bi-file-earmark-excel"></i> Export CSV
                                </a>

                                <a href="/product/new" class="btn btn-primary">
                                    <i class="bi bi-plus-lg"></i> Add Product
                                </a>
                            </div>
                        </div>

                        <div class="card p-4 shadow-sm border-0">
                            <div class="table-responsive">
                                <table class="table table-hover align-middle">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Image</th>
                                            <th>SKU</th>
                                            <th>Name</th>
                                            <th>Price</th>
                                            <th>Stock</th>
                                            <th>Action</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% product.forEach(p=> { %>
                                            <tr>
                                                <td>
                                                    <% if(p.imageUrl) { %>
                                                        <img src="<%= p.imageUrl %>" width="50" height="50"
                                                            class="rounded">
                                                        <% } else { %>
                                                            <span class="badge bg-secondary">No Image</span>
                                                            <% } %>
                                                                <p class="m-0"
                                                                    style="font-weight: 800; color: rgba(142, 141, 141, 0.904);">
                                                                    <%= p.status %>
                                                                </p>
                                                </td>
                                                <td>
                                                    <%= p.sku %>
                                                </td>
                                                <td>
                                                    <%= p.name %>
                                                </td>
                                                <td>₹<%= p.price %>
                                                </td>
                                                <td>
                                                    <%= p.stockQuantity %>
                                                </td>
                                                <td>
                                                    <a href="/product/edit/<%= p._id %>"
                                                        class="btn btn-sm btn-outline-primary me-2"><i
                                                            class="bi bi-pencil"></i>
                                                    </a>
                                                    <form action="/product/delete/<%= p._id %>" method="POST"
                                                        style="display:inline;">
                                                        <button type="submit" class="btn btn-sm btn-outline-danger"><i
                                                                class="bi bi-trash"></i></button>
                                                    </form>
                                                </td>
                                            </tr>
                                            <% }) %>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </main>
            </div>
        </div>
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    </body>

    </html>