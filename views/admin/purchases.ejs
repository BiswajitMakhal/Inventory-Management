<%- include('../layouts/header') %>
<body>
    <div class="container-fluid">
        <div class="row flex-nowrap">
            <%- include('../layouts/sidebar') %>
            
            <main class="col-md-10 ms-sm-auto px-md-4 py-4">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h2 class="fw-bold">📦 Purchases (Stock In)</h2>
                    <a href="/purchase/new" class="btn btn-primary"><i class="bi bi-box-arrow-in-down"></i> Record New Purchase</a>
                </div>

                <div class="card p-4 shadow-sm border-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>Purchase ID</th>
                                    <th>Supplier Name</th>
                                    <th>Total Amount</th>
                                    <th>Date</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if(purchases && purchases.length > 0) { %>
                                    <% purchases.forEach(purchase => { %>
                                        <tr>
                                            <td class="fw-bold text-primary"><%= purchase.purchaseId %></td>
                                            <td><%= purchase.supplierId ? purchase.supplierId.name : 'Unknown' %></td>
                                            <td class="fw-bold text-danger">₹<%= purchase.totalAmount %></td>
                                            <td><%= new Date(purchase.purchaseDate).toLocaleDateString() %></td>
                                            <td><span class="badge bg-success"><i class="bi bi-check-circle"></i> Stock Added</span></td>
                                        </tr>
                                    <% }) %>
                                <% } else { %>
                                    <tr><td colspan="5" class="text-center py-4 text-muted">No purchases recorded yet.</td></tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </main>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>