<%- include('../layouts/header') %>
<body>
    <div class="container-fluid">
        <div class="row">
            <%- include('../layouts/sidebar') %>
            
            <main class="col-md-10 ms-sm-auto px-md-4 py-4">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h2 class="fw-bold">Orders / Sales</h2>
                    <a href="/orders/new" class="btn btn-primary"><i class="bi bi-cart-plus"></i> Create Order</a>
                </div>

                <div class="card p-4 shadow-sm border-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>Order ID</th>
                                    <th>Customer Name</th>
                                    <th>Total Amount</th>
                                    <th>Status</th>
                                    <th>Date</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if(orders && orders.length > 0) { %>
                                    <% orders.forEach(order => { %>
                                        <tr>
                                            <td class="fw-bold"><%= order.orderId %></td>
                                            <td><%= order.userId ? order.userId.name : 'Unknown' %></td>
                                            <td>₹<%= order.totalAmount %></td>
                                            <td>
                                                <span class="badge <%= order.status === 'Completed' ? 'bg-success' : (order.status === 'Cancelled' ? 'bg-danger' : 'bg-warning') %>">
                                                    <%= order.status %>
                                                </span>
                                            </td>
                                            <td><%= new Date(order.createdAt).toLocaleDateString() %></td>
                                            <td>
                                                <% if(order.status !== 'Cancelled') { %>
                                                <form action="/order/cancel/<%= order._id %>" method="POST" style="display:inline;">
                                                    <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Are you sure you want to cancel this order?')">Cancel</button>
                                                </form>
                                                <% } else { %>
                                                    <span class="text-muted">Cancelled</span>
                                                <% } %>
                                            </td>
                                        </tr>
                                    <% }) %>
                                <% } else { %>
                                    <tr><td colspan="6" class="text-center">No orders found.</td></tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </main>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>