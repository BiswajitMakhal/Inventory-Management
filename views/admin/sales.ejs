<%- include('../layouts/header') %>

    <body>
        <div class="container-fluid">
            <div class="row flex-nowrap">
                <%- include('../layouts/sidebar') %>

                    <main class="col-md-10 ms-sm-auto px-md-4 py-4">
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <h2 class="fw-bold">Orders / Sales</h2>
                            <a href="/orders/new" class="btn btn-primary"><i class="bi bi-cart-plus"></i> Create
                                Order</a>
                        </div>

                        <div class="card p-3 shadow-sm border-0 mb-4 bg-light">
                            <form action="/orders" method="GET" class="d-flex w-50">
                                <input type="text" name="search" class="form-control me-2"
                                    placeholder="Search by Order ID (e.g., ORD-123)"
                                    value="<%= typeof search !== 'undefined' ? search : '' %>">
                                <button type="submit" class="btn btn-dark">Search</button>

                                <% if(typeof search !=='undefined' && search !=='' ) { %>
                                    <a href="/orders" class="btn btn-outline-danger ms-2">Clear</a>
                                    <% } %>
                            </form>
                        </div>

                        <div class="card p-4 shadow-sm border-0">
                            <div class="table-responsive">
                                <table class="table table-hover align-middle">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Order ID</th>
                                            <th>Customer Name</th>
                                            <th>Total Amount</th>
                                            <th>Status</th>
                                            <th>Date</th>
                                            <th class="text-center">Action</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% if(orders && orders.length> 0) { %>
                                            <% orders.forEach(order=> { %>
                                                <tr>
                                                    <td class="fw-bold">
                                                        <%= order.orderId %>
                                                    </td>
                                                    <td>
                                                        <%= order.userId ? order.userId.name : 'Unknown' %>
                                                    </td>
                                                    <td>₹<%= order.totalAmount %>
                                                    </td>
                                                    <td>
                                                        <span
                                                            class="badge <%= order.status === 'Completed' ? 'bg-success' : (order.status === 'Cancelled' ? 'bg-danger' : 'bg-warning text-dark') %>">
                                                            <%= order.status %>
                                                        </span>
                                                    </td>
                                                    <td>
                                                        <%= new Date(order.createdAt).toLocaleDateString() %>
                                                    </td>
                                                    <td class="text-center">
                                                        <div class="d-flex gap-2 justify-content-center">
                                                            <% if (order.status==='Pending' ) { %>
                                                                <form action="/orders/pay/<%= order._id %>"
                                                                    method="POST" style="display:inline;">
                                                                    <input type="hidden" name="totalAmount"
                                                                        value="<%= order.totalAmount %>">
                                                                    <button type="submit"
                                                                        class="btn btn-sm btn-success">
                                                                        <i class="bi bi-cash-stack"></i> Pay
                                                                    </button>
                                                                </form>

                                                                <form action="/order/cancel/<%= order._id %>"
                                                                    method="POST" style="display:inline;">
                                                                    <button type="submit"
                                                                        class="btn btn-sm btn-outline-danger"
                                                                        onclick="return confirm('Are you sure?')">
                                                                        <i class="bi bi-x-circle"></i> Cancel
                                                                    </button>
                                                                </form>
                                                                <% } else if (order.status==='Cancelled' ) { %>
                                                                    <span
                                                                        class="text-danger small fw-bold text-uppercase">No
                                                                        Action</span>
                                                                    <% } else { %>
                                                                        <span
                                                                            class="text-success small fw-bold text-uppercase">
                                                                            <i class="bi bi-check-all"></i> Finalized
                                                                        </span>
                                                                        <% } %>
                                                        </div>
                                                    </td>
                                                </tr>
                                                <% }) %>
                                                    <% } else { %>
                                                        <tr>
                                                            <td colspan="6" class="text-center py-4 text-muted">No
                                                                orders found.</td>
                                                        </tr>
                                                        <% } %>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </main>
            </div>
        </div>
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    </body>

    </html>