<%- include('../layouts/header') %>
<body>
    <div class="container-fluid">
        <div class="row">
            <%- include('../layouts/sidebar') %>

            <main class="col-md-10 col-12 ms-md-auto px-3 px-md-4 py-3 py-md-4">
                <div class="d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center mb-4 gap-3">
                    <h2 class="fw-bold m-0">Orders / Sales</h2>
                    <a href="/orders/new" class="btn btn-primary btn-sm w-100 w-sm-auto"><i class="bi bi-cart-plus"></i> Create Order</a>
                </div>

                <div class="card p-3 p-md-4 shadow-sm border-0 mb-4 bg-light">
                    <form action="/orders" method="GET" class="d-flex w-100 w-md-50 gap-2">
                        <input type="text" name="search" class="form-control" placeholder="Search Order ID (e.g., ORD-123)" value="<%= typeof search !== 'undefined' ? search : '' %>">
                        <button type="submit" class="btn btn-dark fw-bold">Search</button>
                        <% if(typeof search !=='undefined' && search !=='' ) { %>
                            <a href="/orders" class="btn btn-outline-danger fw-bold">Clear</a>
                        <% } %>
                    </form>
                </div>

                <div class="card p-3 p-md-4 shadow-sm border-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle text-nowrap">
                            <thead class="table-light">
                                <tr>
                                    <th>Order ID</th>
                                    <th>Customer Name</th>
                                    <th>Total Amount</th>
                                    <th>Status</th>
                                    <th>Date</th>
                                    <th class="text-center">Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if(orders && orders.length > 0) { %>
                                    <% orders.forEach(order => { %>
                                        <tr>
                                            <td class="fw-bold"><%= order.orderId %></td>
                                            <td><%= order.userId ? order.userId.name : 'Unknown' %></td>
                                            <td class="fw-medium">₹<%= order.totalAmount %></td>
                                            <td>
                                                <span class="badge <%= order.status === 'Completed' ? 'bg-success' : (order.status === 'Cancelled' ? 'bg-danger' : 'bg-warning text-dark') %>">
                                                    <%= order.status %>
                                                </span>
                                            </td>
                                            <td class="small"><%= new Date(order.createdAt).toLocaleDateString() %></td>
                                            <td class="text-center">
                                                <% if (order.status !== 'Cancelled') { %>
                                                    <form action="/order/cancel/<%= order._id %>" method="POST" style="display:inline;">
                                                        <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Cancel this order?')">
                                                            <i class="bi bi-x-circle"></i> Cancel
                                                        </button>
                                                    </form>
                                                <% } else { %>
                                                    <span class="text-muted small">No Action</span>
                                                <% } %>
                                            </td>
                                        </tr>
                                    <% }) %>
                                <% } else { %>
                                    <tr><td colspan="6" class="text-center py-4 text-muted small">No orders found.</td></tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </main>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>