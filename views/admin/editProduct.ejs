<%- include('../layouts/header') %>

    <body>
        <div class="container-fluid">
            <div class="row">
                <%- include('../layouts/sidebar') %>
                    <main class="col-md-10 ms-sm-auto px-md-4 py-4">
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <h2 class="fw-bold">Edit Product</h2>
                            <a href="/products" class="btn btn-outline-secondary">Back to Products</a>
                        </div>
                        <div class="card p-4 shadow-sm border-0">
                            <form action="/product/update/<%= product._id %>" method="POST"
                                enctype="multipart/form-data">
                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <label class="form-label">Product Name</label>
                                        <input type="text" name="name" class="form-control" value="<%= product.name %>"
                                            required>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label">SKU</label>
                                        <input type="text" name="sku" class="form-control" value="<%= product.sku %>"
                                            required>
                                    </div>

                                    <div class="col-md-6">
                                        <label class="form-label">Category</label>
                                        <select name="categoryId" class="form-select" required>
                                            <% categories.forEach(cat=> { %>
                                                <option value="<%= cat._id %>"
                                                    <%=(cat._id.toString()===product.categoryId.toString()) ? 'selected'
                                                    : '' %>><%= cat.name %>
                                                </option>
                                                <% }) %>
                                        </select>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label">Supplier</label>
                                        <select name="supplierId" class="form-select" required>
                                            <% suppliers.forEach(sup=> { %>
                                                <option value="<%= sup._id %>"
                                                    <%=(sup._id.toString()===product.supplierId.toString()) ? 'selected'
                                                    : '' %>><%= sup.name %>
                                                </option>
                                                <% }) %>
                                        </select>
                                    </div>

                                    <div class="col-md-4">
                                        <label class="form-label">Price (₹)</label>
                                        <input type="number" name="price" class="form-control"
                                            value="<%= product.price %>" required>
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label">Stock Quantity</label>
                                        <input type="number" name="stockQuantity" class="form-control"
                                            value="<%= product.stockQuantity %>" required>
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label">Min Stock Level</label>
                                        <input type="number" name="minStockLevel" class="form-control"
                                            value="<%= product.minStockLevel %>" required>
                                    </div>

                                    <div class="col-md-6">
                                        <label class="form-label">Status</label>
                                        <select name="status" class="form-select">
                                            <option value="Active" <%=product.status==='Active' ? 'selected' : '' %>
                                                >Active</option>
                                            <option value="Inactive" <%=product.status==='Inactive' ? 'selected' : '' %>
                                                >Inactive</option>
                                        </select>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label">Update Image (Leave blank to keep current
                                            image)</label>
                                        <input type="file" name="image" class="form-control"
                                            accept="image/png, image/jpeg, image/jpg">
                                    </div>

                                    <div class="col-12 mt-4">
                                        <button type="submit" class="btn btn-primary px-4">Update Product</button>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </main>
            </div>
        </div>
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    </body>

    </html>