<%- include('../layouts/header') %>
<body>
    <div class="container-fluid">
        <div class="row flex-nowrap">
            <%- include('../layouts/sidebar') %>
            
            <main class="col-md-10 ms-sm-auto px-md-4 py-4">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h2 class="fw-bold">💰 Payment & Due Tracking</h2>
                    <div class="badge bg-danger p-2 fs-6 shadow-sm">
                        Action Required: Collect Pending Dues
                    </div>
                </div>

                <div class="row mb-4">
                    <div class="col-md-4">
                        <div class="card border-0 shadow-sm bg-primary text-white p-3">
                            <h6 class="text-uppercase small">Total Collections Expected</h6>
                            <h3 class="fw-bold mb-0">
                                ₹<%= payments.reduce((acc, curr) => acc + curr.totalAmount, 0) %>
                            </h3>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card border-0 shadow-sm bg-success text-white p-3">
                            <h6 class="text-uppercase small">Total Received</h6>
                            <h3 class="fw-bold mb-0">
                                ₹<%= payments.reduce((acc, curr) => acc + curr.paidAmount, 0) %>
                            </h3>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card border-0 shadow-sm bg-danger text-white p-3">
                            <h6 class="text-uppercase small">Total Pending Due</h6>
                            <h3 class="fw-bold mb-0">
                                ₹<%= payments.reduce((acc, curr) => acc + curr.dueAmount, 0) %>
                            </h3>
                        </div>
                    </div>
                </div>

                <div class="card p-4 shadow-sm border-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>Order ID</th>
                                    <th>Customer</th>
                                    <th>Total Bill</th>
                                    <th>Paid</th>
                                    <th>Due Amount</th>
                                    <th>Payment Status</th>
                                    <th class="text-center">Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if(payments && payments.length > 0) { %>
                                    <% payments.forEach(payment => { %>
                                        <tr>
                                            <td class="fw-bold text-primary">
                                                <%= payment.orderId ? payment.orderId.orderId : 'N/A' %>
                                            </td>
                                            <td>
                                                <%= (payment.orderId && payment.orderId.userId) ? payment.orderId.userId.name : 'Walking Customer' %>
                                            </td>
                                            <td>₹<%= payment.totalAmount %></td>
                                            <td class="text-success fw-semibold">₹<%= payment.paidAmount %></td>
                                            <td class="text-danger fw-bold">₹<%= payment.dueAmount %></td>
                                            <td>
                                                <span class="badge rounded-pill <%= payment.status === 'Paid' ? 'bg-success' : (payment.status === 'Partial' ? 'bg-warning text-dark' : 'bg-danger') %>">
                                                    <%= payment.status %>
                                                </span>
                                            </td>
                                            <td class="text-center">
                                                <% if(payment.status !== 'Paid') { %>
                                                    <button class="btn btn-sm btn-dark shadow-sm" data-bs-toggle="modal" data-bs-target="#payModal<%= payment._id %>">
                                                        <i class="bi bi-cash-coin"></i> Collect Pay
                                                    </button>
                                                <% } else { %>
                                                    <span class="text-success small fw-bold">
                                                        <i class="bi bi-check-all fs-5"></i> CLEARED
                                                    </span>
                                                <% } %>
                                            </td>
                                        </tr>

                                        <div class="modal fade" id="payModal<%= payment._id %>" tabindex="-1" aria-hidden="true">
                                            <div class="modal-dialog modal-dialog-centered">
                                                <div class="modal-content border-0 shadow">
                                                    <form action="/payments/create" method="POST">
                                                        <div class="modal-header bg-light">
                                                            <h5 class="modal-title fw-bold">Record Payment Update</h5>
                                                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                                        </div>
                                                        <div class="modal-body p-4">
                                                            <input type="hidden" name="orderId" value="<%= payment.orderId ? payment.orderId._id : '' %>">
                                                            
                                                            <div class="text-center mb-4">
                                                                <p class="text-muted mb-1">Current Outstanding Balance</p>
                                                                <h2 class="text-danger fw-bold">₹<%= payment.dueAmount %></h2>
                                                            </div>

                                                            <div class="mb-3">
                                                                <label class="form-label fw-semibold">Amount Received Now</label>
                                                                <div class="input-group">
                                                                    <span class="input-group-text">₹</span>
                                                                    <input type="number" name="amountPaid" class="form-control form-control-lg" 
                                                                           max="<%= payment.dueAmount %>" placeholder="0.00" required>
                                                                </div>
                                                                <small class="text-muted">Enter the amount the customer just paid.</small>
                                                            </div>

                                                            <div class="mb-3">
                                                                <label class="form-label fw-semibold">Payment Method</label>
                                                                <select name="paymentMethod" class="form-select">
                                                                    <option value="Cash">💵 Cash</option>
                                                                    <option value="Card">💳 Card</option>
                                                                    <option value="Online">📱 Online/UPI</option>
                                                                </select>
                                                            </div>
                                                        </div>
                                                        <div class="modal-footer bg-light border-0">
                                                            <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                                                            <button type="submit" class="btn btn-success px-4"> Confirm Payment</button>
                                                        </div>
                                                    </form>
                                                </div>
                                            </div>
                                        </div>
                                    <% }) %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="7" class="text-center py-5">
                                            <img src="https://cdn-icons-png.flaticon.com/512/4076/4076549.png" width="80" class="mb-3 opacity-50">
                                            <p class="text-muted">No pending or due payments found in the system.</p>
                                        </td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </main>
        </div>
    </div>
    
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>