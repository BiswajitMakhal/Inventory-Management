<%- include('../layouts/user-header') %>

<div class="container pb-5">
    <h2 class="fw-bold mb-4" style="color: #1e293b;">Shopping Cart</h2>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="modern-card">
                <div class="card-body p-0">
                    <div class="table-responsive table-modern">
                        <table class="table align-middle mb-0 table-hover">
                            <thead style="background-color: #f8fafc;">
                                <tr>
                                    <th class="ps-4 py-3 border-0">Product</th>
                                    <th class="py-3 border-0">Price</th>
                                    <th class="py-3 border-0">Quantity</th>
                                    <th class="py-3 border-0">Total</th>
                                    <th class="pe-4 py-3 border-0 text-center">Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if(cartItems && cartItems.length > 0) { %>
                                    <% cartItems.forEach(item => { %>
                                        <tr>
                                            <td class="ps-4 py-3 fw-medium text-dark"><%= item.productName %></td>
                                            <td class="py-3 text-secondary">₹<%= item.price %></td>
                                            <td class="py-3">
                                                <span class="badge bg-light text-dark px-3 py-2 border rounded-pill"><%= item.quantity %></span>
                                            </td>
                                            <td class="fw-bold py-3 text-dark">₹<%= item.price * item.quantity %></td>
                                            <td class="pe-4 py-3 text-center">
                                                <form action="/user/cart/remove/<%= item.productId %>" method="POST">
                                                    <button type="submit" class="btn btn-sm btn-outline-danger rounded-circle p-2" title="Remove Item">
                                                        <i class="bi bi-trash ms-1 me-1"></i>
                                                    </button>
                                                </form>
                                            </td>
                                        </tr>
                                    <% }) %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="5" class="text-center py-5">
                                            <i class="bi bi-cart-x text-muted" style="font-size: 3rem; opacity: 0.3;"></i>
                                            <p class="mt-3 mb-0 fs-5 text-muted fw-medium">Your cart is empty.</p>
                                        </td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="modern-card p-4 bg-white" style="border: 1px solid #e2e8f0;">
                <h5 class="fw-bold mb-4" style="color: #1e293b;">Order Summary</h5>
                <div class="d-flex justify-content-between mb-3 text-secondary">
                    <span>Subtotal</span>
                    <span class="fw-medium text-dark">₹<%= cartTotal || 0 %></span>
                </div>
                <div class="d-flex justify-content-between mb-3 text-secondary">
                    <span>Tax & Fees</span>
                    <span class="text-success">Calculated at checkout</span>
                </div>
                <hr style="border-color: #cbd5e1;">
                <div class="d-flex justify-content-between mb-4 mt-2">
                    <span class="fw-bold fs-5" style="color: #1e293b;">Total</span>
                    <span class="fw-bold fs-4" style="color: #4f46e5;">₹<%= cartTotal || 0 %></span>
                </div>

                <% if(cartItems && cartItems.length > 0) { %>
                    <form action="/user/checkout" method="POST">
                        <button type="submit" class="btn btn-modern w-100 py-3 text-white shadow-sm" style="background: linear-gradient(135deg, #10b981 0%, #059669 100%); border: none;">
                            <i class="bi bi-lock me-2"></i> Checkout Securely
                        </button>
                    </form>
                <% } else { %>
                    <a href="/user/home" class="btn btn-modern w-100 py-3 text-white shadow-sm" style="background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%);">
                        <i class="bi bi-arrow-left me-2"></i> Continue Shopping
                    </a>
                <% } %>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>