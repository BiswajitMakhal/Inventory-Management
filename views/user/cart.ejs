<%- include('../layouts/user-header') %>

<div class="container pb-5">
    <h2 class="fw-bold mb-4 px-2 px-md-0" style="color: #1e293b;">Shopping Cart</h2>

    <div class="row g-3 g-md-4">
        <div class="col-12 col-lg-8">
            <div class="modern-card p-0">
                <div class="table-responsive table-modern m-0">
                    <table class="table align-middle mb-0 table-hover text-nowrap">
                        <thead style="background-color: #f8fafc;">
                            <tr>
                                <th class="ps-3 ps-md-4 py-3 border-0">Product</th>
                                <th class="py-3 border-0">Price</th>
                                <th class="py-3 border-0">Qty</th>
                                <th class="py-3 border-0">Total</th>
                                <th class="pe-3 pe-md-4 py-3 border-0 text-center">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if(cartItems && cartItems.length > 0) { %>
                                <% cartItems.forEach(item => { %>
                                    <tr>
                                        <td class="ps-3 ps-md-4 py-3 fw-medium text-dark text-truncate" style="max-width: 120px;" title="<%= item.productName %>"><%= item.productName %></td>
                                        <td class="py-3 text-secondary small">₹<%= item.price %></td>
                                        <td class="py-3">
                                            <span class="badge bg-light text-dark px-2 py-1 border rounded"><%= item.quantity %></span>
                                        </td>
                                        <td class="fw-bold py-3 text-dark small">₹<%= item.price * item.quantity %></td>
                                        <td class="pe-3 pe-md-4 py-3 text-center">
                                            <form action="/user/cart/remove/<%= item.productId %>" method="POST" class="m-0">
                                                <button type="submit" class="btn btn-sm btn-outline-danger rounded p-1 p-md-2" title="Remove Item">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                <% }) %>
                            <% } else { %>
                                <tr>
                                    <td colspan="5" class="text-center py-5">
                                        <i class="bi bi-cart-x text-muted" style="font-size: 3rem; opacity: 0.3;"></i>
                                        <p class="mt-3 mb-0 fs-6 text-muted fw-medium">Your cart is empty.</p>
                                    </td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-12 col-lg-4">
            <div class="modern-card p-3 p-md-4 bg-white" style="border: 1px solid #e2e8f0;">
                <h5 class="fw-bold mb-3 mb-md-4" style="color: #1e293b;">Order Summary</h5>
                <div class="d-flex justify-content-between mb-2 mb-md-3 text-secondary small fw-medium">
                    <span>Subtotal</span>
                    <span class="text-dark">₹<%= cartTotal || 0 %></span>
                </div>
                <div class="d-flex justify-content-between mb-2 mb-md-3 text-secondary small fw-medium">
                    <span>Tax & Fees</span>
                    <span class="text-success">Calculated later</span>
                </div>
                <hr style="border-color: #cbd5e1; margin: 15px 0;">
                <div class="d-flex justify-content-between align-items-center mb-4 mt-2">
                    <span class="fw-bold fs-5" style="color: #1e293b;">Total</span>
                    <span class="fw-bold fs-4" style="color: #4f46e5;">₹<%= cartTotal || 0 %></span>
                </div>

                <% if(cartItems && cartItems.length > 0) { %>
                    <form action="/user/checkout" method="POST">
                        <button type="submit" class="btn btn-modern w-100 py-3 text-white shadow-sm fw-bold" style="background: linear-gradient(135deg, #10b981 0%, #059669 100%); border: none;">
                            <i class="bi bi-lock me-2"></i> Checkout
                        </button>
                    </form>
                <% } else { %>
                    <a href="/user/home" class="btn btn-modern w-100 py-3 text-white shadow-sm fw-bold d-block text-center text-decoration-none" style="background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%);">
                        <i class="bi bi-arrow-left me-2"></i> Shop Now
                    </a>
                <% } %>
            </div>
        </div>
    </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>