<%- include('../layouts/user-header') %>

    <div class="container">
        <h2 class="fw-bold mb-4">My Orders</h2>

        <div class="card border-0 shadow-sm p-4">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Order ID</th>
                            <th>Date</th>
                            <th>Total Amount</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if(orders && orders.length> 0) { %>
                            <% orders.forEach(order=> { %>
                                <tr>
                                    <td class="fw-bold">#<%= order.orderId %>
                                    </td>
                                    <td>
                                        <%= new Date(order.createdAt).toLocaleDateString() %>
                                    </td>
                                    <td>₹<%= order.totalAmount %>
                                    </td>
                                    <td>
                                        <span
                                            class="badge <%= order.status === 'Completed' ? 'bg-success' : (order.status === 'Cancelled' ? 'bg-danger' : 'bg-warning') %>">
                                            <%= order.status %>
                                        </span>
                                    </td>
                                </tr>
                                <% }) %>
                                    <% } else { %>
                                        <tr>
                                            <td colspan="4" class="text-center py-4 text-muted">You haven't placed any
                                                orders yet.</td>
                                        </tr>
                                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    </body>

    </html>