<%- include('../layouts/user-header') %>

<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">Latest Products</h2>
    </div>

    <div class="row g-4">
        <% if(products && products.length > 0) { %>
            <% products.forEach(product => { %>
                <div class="col-md-3 col-sm-6">
                    <div class="card h-100 border-0 shadow-sm product-card">
                        <% if(product.imageUrl) { %>
                            <img src="<%= product.imageUrl %>" class="card-img-top p-3 rounded" alt="<%= product.name %>" style="height: 200px; object-fit: contain;">
                        <% } else { %>
                            <div class="card-img-top bg-light d-flex align-items-center justify-content-center" style="height: 200px;">
                                <i class="bi bi-image text-muted fs-1"></i>
                            </div>
                        <% } %>
                        <div class="card-body d-flex flex-column">
                            <span class="badge bg-secondary mb-2 align-self-start"><%= product.categoryId ? product.categoryId.name : 'General' %></span>
                            <h5 class="card-title fw-bold text-truncate" title="<%= product.name %>"><%= product.name %></h5>
                            <p class="text-success fw-bold fs-5 mb-3">₹<%= product.price %></p>
                            
                            <form action="/user/cart/add" method="POST" class="mt-auto">
                                <input type="hidden" name="productId" value="<%= product._id %>">
                                <div class="input-group mb-2">
                                    <input type="number" name="quantity" class="form-control" value="1" min="1" max="<%= product.stockQuantity %>" required>
                                </div>
                                <% if(product.stockQuantity > 0) { %>
                                    <button type="submit" class="btn btn-primary w-100"><i class="bi bi-cart-plus"></i> Add to Cart</button>
                                <% } else { %>
                                    <button type="button" class="btn btn-danger w-100" disabled>Out of Stock</button>
                                <% } %>
                            </form>
                        </div>
                    </div>
                </div>
            <% }) %>
        <% } else { %>
            <div class="col-12 text-center py-5">
                <h4 class="text-muted">No products available right now.</h4>
            </div>
        <% } %>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>