<%- include('../layouts/user-header') %>

<div class="container pb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold m-0" style="color: #1e293b;">Latest Arrival</h2>
        <span class="badge bg-primary-subtle text-primary rounded-pill px-3 py-2 fs-6 border border-primary-subtle">Shop Now</span>
    </div>

    <div class="row g-4">
        <% if(products && products.length > 0) { %>
            <% products.forEach(product => { %>
                <div class="col-lg-3 col-md-4 col-sm-6">
                    <div class="card modern-card h-100 d-flex flex-column">
                        <div class="bg-light p-4 d-flex justify-content-center align-items-center" style="height: 220px;">
                            <% if(product.imageUrl) { %>
                                <img src="<%= product.imageUrl %>" class="img-fluid" alt="<%= product.name %>" style="max-height: 100%; object-fit: contain; mix-blend-mode: multiply;">
                            <% } else { %>
                                <i class="bi bi-image text-muted" style="font-size: 4rem; opacity: 0.3;"></i>
                            <% } %>
                        </div>
                        
                        <div class="card-body d-flex flex-column p-4">
                            <span class="badge bg-secondary-subtle text-secondary rounded-pill mb-3 align-self-start fw-medium px-3"><%= product.categoryId ? product.categoryId.name : 'General' %></span>
                            <h5 class="card-title fw-bold text-truncate mb-2" title="<%= product.name %>" style="color: #1e293b;"><%= product.name %></h5>
                            <p class="fw-bold fs-4 mb-4" style="color: #4f46e5;">₹<%= product.price %></p>
                            
                            <form action="/user/cart/add" method="POST" class="mt-auto">
                                <input type="hidden" name="productId" value="<%= product._id %>">
                                <div class="d-flex gap-2 align-items-center mb-3">
                                    <label class="text-muted fw-medium small">Qty:</label>
                                    <input type="number" name="quantity" class="form-control text-center rounded-3 border-0 bg-light" value="1" min="1" max="<%= product.stockQuantity %>" required style="max-width: 80px;">
                                </div>
                                <% if(product.stockQuantity > 0) { %>
                                    <button type="submit" class="btn btn-dark btn-modern w-100 py-2 d-flex justify-content-center align-items-center gap-2">
                                        <i class="bi bi-cart-plus fs-5"></i> Add to Cart
                                    </button>
                                <% } else { %>
                                    <button type="button" class="btn btn-outline-danger btn-modern w-100 py-2 fw-bold" disabled>Out of Stock</button>
                                <% } %>
                            </form>
                        </div>
                    </div>
                </div>
            <% }) %>
        <% } else { %>
            <div class="col-12 text-center py-5 my-5">
                <i class="bi bi-box-seam text-muted" style="font-size: 5rem; opacity: 0.2;"></i>
                <h3 class="text-muted mt-3 fw-bold">No products available right now.</h3>
                <p class="text-secondary">Please check back later!</p>
            </div>
        <% } %>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>