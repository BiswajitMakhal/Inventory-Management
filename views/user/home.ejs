<%- include('../layouts/user-header') %>

<div class="container pb-5">
    <div class="d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center mb-4 gap-2">
        <h2 class="fw-bold m-0" style="color: #1e293b;">Latest Arrival</h2>
        <span class="badge bg-primary-subtle text-primary rounded-pill px-3 py-2 fs-6 border border-primary-subtle">Shop Now</span>
    </div>

    <div class="row g-3 g-md-4">
        <% if(products && products.length > 0) { %>
            <% products.forEach(product => { %>
                <div class="col-12 col-sm-6 col-md-4 col-lg-3">
                    <div class="card modern-card h-100 d-flex flex-column">
                        <div class="bg-light p-3 p-md-4 d-flex justify-content-center align-items-center rounded-top" style="height: 200px;">
                            <% if(product.imageUrl) { %>
                                <img src="<%= product.imageUrl %>" class="img-fluid" alt="<%= product.name %>" style="max-height: 100%; object-fit: contain; mix-blend-mode: multiply;">
                            <% } else { %>
                                <i class="bi bi-image text-muted" style="font-size: 4rem; opacity: 0.3;"></i>
                            <% } %>
                        </div>
                        
                        <div class="card-body d-flex flex-column p-3 p-md-4">
                            <span class="badge bg-secondary-subtle text-secondary rounded-pill mb-2 align-self-start fw-medium px-2 py-1" style="font-size: 0.7rem;"><%= product.categoryId ? product.categoryId.name : 'General' %></span>
                            <h5 class="card-title fw-bold text-truncate mb-1" title="<%= product.name %>" style="color: #1e293b;"><%= product.name %></h5>
                            <p class="fw-bold fs-5 mb-3" style="color: #4f46e5;">₹<%= product.price %></p>
                            
                            <form action="/user/cart/add" method="POST" class="mt-auto">
                                <input type="hidden" name="productId" value="<%= product._id %>">
                                <div class="d-flex gap-2 align-items-center mb-3">
                                    <label class="text-muted fw-medium small">Qty:</label>
                                    <input type="number" name="quantity" class="form-control form-control-sm text-center rounded-2 border-0 bg-light" value="1" min="1" max="<%= product.stockQuantity %>" required style="max-width: 70px;">
                                </div>
                                <% if(product.stockQuantity > 0) { %>
                                    <button type="submit" class="btn btn-dark btn-modern w-100 py-2 d-flex justify-content-center align-items-center gap-2 fw-bold text-nowrap">
                                        <i class="bi bi-cart-plus fs-6"></i> Add to Cart
                                    </button>
                                <% } else { %>
                                    <button type="button" class="btn btn-outline-danger btn-modern w-100 py-2 fw-bold" disabled>Out of Stock</button>
                                <% } %>
                            </form>
                        </div>
                    </div>
                </div>
            <% }) %>
        <% } else { %>
            <div class="col-12 text-center py-5 my-5 px-3">
                <i class="bi bi-box-seam text-muted" style="font-size: 5rem; opacity: 0.2;"></i>
                <h4 class="text-muted mt-3 fw-bold">No products available right now.</h4>
                <p class="text-secondary small">Please check back later!</p>
            </div>
        <% } %>
    </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>