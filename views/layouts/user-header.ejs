<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>InvPro - Shop</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <style>
        body {
            font-family: 'Poppins', sans-serif;
            background-color: #f4f7fa; /* Soft premium background */
            color: #2b3445;
        }

        /* Modern Gradient Navbar */
        .navbar-custom {
            background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%);
            padding: 15px 0;
            box-shadow: 0 4px 15px rgba(0,0,0,0.08);
        }

        /* Premium Card Design */
        .modern-card {
            border: none;
            border-radius: 16px;
            background: #fff;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.04);
            transition: all 0.3s ease;
            overflow: hidden;
        }

        .modern-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 15px 30px rgba(0, 0, 0, 0.1);
        }

        /* Modern Button Styling */
        .btn-modern {
            border-radius: 10px;
            font-weight: 500;
            transition: all 0.2s ease;
        }
        
        .btn-modern:hover {
            transform: scale(1.02);
        }

        /* Table modern look */
        .table-modern {
            border-radius: 16px;
            overflow: hidden;
        }
        .table-modern th {
            font-weight: 600;
            text-transform: uppercase;
            font-size: 0.85rem;
            letter-spacing: 0.5px;
            color: #6b7280;
        }
    </style>
</head>

<body>
    <nav class="navbar navbar-expand-lg navbar-dark navbar-custom mb-5">
        <div class="container">
            <a class="navbar-brand fw-bold fs-4" href="/user/home">
                <i class="bi bi-shop me-2"></i>InvPro Store
            </a>
            <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <i class="bi bi-list fs-1"></i>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto align-items-center">
                    <li class="nav-item mx-2">
                        <a class="nav-link text-white fw-medium" href="/user/home"><i class="bi bi-house-door me-1"></i> Home</a>
                    </li>
                    <li class="nav-item mx-2">
                        <a class="nav-link text-white fw-medium" href="/user/cart"><i class="bi bi-cart3 me-1"></i> Cart</a>
                    </li>
                    <li class="nav-item mx-2">
                        <a class="nav-link text-white fw-medium" href="/user/orders"><i class="bi bi-box-seam me-1"></i> Orders</a>
                    </li>
                    <li class="nav-item ms-lg-3 mt-2 mt-lg-0">
                        <form action="/logout" method="POST" class="d-inline">
                            <button type="submit" class="btn btn-light btn-sm fw-bold text-primary rounded-pill px-3 py-2 shadow-sm">
                                <i class="bi bi-box-arrow-right"></i> Logout
                            </button>
                        </form>
                    </li>
                </ul>
            </div>
        </div>
    </nav>