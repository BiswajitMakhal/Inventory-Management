<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>InvPro - Login</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            background: linear-gradient(135deg, #0f172a, #1e293b);
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .auth-card {
            width: 100%;
            max-width: 400px;
            border: none;
            border-radius: 16px;
            padding: 25px;
            background: #ffffff;
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.2);
        }

        .auth-title {
            font-weight: 700;
            color: #0f172a;
        }

        .form-control {
            border-radius: 10px;
        }

        .btn-primary {
            border-radius: 10px;
        }

        /*  ADMIN DEMO */
        .admin-demo {
            background: linear-gradient(135deg, #3b82f6, #6366f1);
            border-radius: 12px;
            padding: 15px;
            margin-top: 20px;
            color: white;
            position: relative;
        }

        .admin-demo h6 {
            font-weight: 600;
            margin-bottom: 8px;
        }

        .admin-demo p {
            margin: 0;
            font-size: 13px;
            opacity: 0.9;
        }

        .copy-btn {
            position: absolute;
            top: 10px;
            right: 10px;
            border: none;
            background: white;
            color: #333;
            font-size: 12px;
            padding: 3px 8px;
            border-radius: 6px;
            cursor: pointer;
        }

        .copy-btn:hover {
            background: #e2e8f0;
        }
    </style>
</head>

<body>

    <div class="card auth-card">
        <div class="text-center mb-4">
            <h2 class="auth-title">InvPro</h2>
            <p class="text-muted">Welcome back! Please login.</p>
        </div>

        <form action="/login" method="POST">
            <div class="mb-3">
                <label class="form-label fw-semibold">Email Address</label>
                <input type="email" name="email" class="form-control p-2" placeholder="name@example.com" required>
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">Password</label>
                <input type="password" name="password" class="form-control p-2" placeholder="••••••••" required>
            </div>

            <button type="submit" class="btn btn-primary w-100 py-2 fw-bold mt-2">Login</button>
        </form>

        <!-- ADMIN DEMO -->
        <div class="admin-demo">
            <h6>Admin Demo</h6>
            <p id="demoText">
                Email: biswajitmakhal@gmail.com <br>
                Password: 1721
            </p>
        </div>

        <div class="text-center mt-3">
            <p class="mb-0 text-muted">
                Don't have an account?
                <a href="/register" class="text-decoration-none fw-bold">Register here</a>
            </p>
        </div>
    </div>

</body>

</html>